# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=familytree
POSTGRES_HOST=db          # "db" for Docker, "localhost" for local dev
POSTGRES_PORT=5432

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Server
SERVER_PORT=8080

# Optional
# DB_SSLMODE=disable      # "require" for production
# BACKUP_DIR=/app/backups  # path for database backups
